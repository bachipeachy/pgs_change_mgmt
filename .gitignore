# =========================
# PGS Change Management
# =========================

# Governance projections produced during authoring sessions (user-specific)
drafts/

# Governance Conversation Records (GCR) — local by default
# To commit a GCR as governance evidence: git add -f sessions/GCR_<ID>.jsonl
sessions/

# Change management generated outputs — agent output, not compiler output
change_mgmt/generated/

# Engine run output (audit trails) — written by engine.run(); not source
engine_runs/

# Dossier checkpoint state — persisted gov_projection handoffs between stages (run state,
# reviewable locally, regenerated each run); not source. Matches any subdomain's dossier.
_handoff/

# Guided Authoring Mode Stage Packages — exported prompt bundles + human-pasted responses
# (run state, reviewable locally, regenerated from the seed each run); not source. Matches any
# subdomain's dossier. To commit one as governance evidence: git add -f <dossier>/_packages/...
_packages/

